<UserControl
    x:Class="Admin.Desktop.UserControls.PaginationPlus"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="40"
    d:DesignWidth="420"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <hc:UniformSpacingPanel
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Orientation="Horizontal"
        Spacing="10">
        <!--  底层Handy分页控件，完全绑定外层暴露属性  -->
        <hc:Pagination
            x:Name="PaginationMain"
            VerticalAlignment="Center"
            DataCountPerPage="{Binding DataCountPerPage, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
            IsJumpEnabled="{Binding IsJumpEnabled, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
            MaxPageCount="{Binding MaxPageCount, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
            MaxPageInterval="{Binding MaxPageInterval, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
            Visibility="Visible"
            PageIndex="{Binding PageIndex, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" />

        <!--  总条数展示  -->
        <TextBlock Padding="0,6" VerticalAlignment="Center">
            <Run Text="共" />
            <Run Text="&#x20;" />
            <Run Text="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <Run Text="&#x20;" />
            <Run Text="条" />
        </TextBlock>

        <!--  每页条数下拉选择器  -->
        <hc:ComboBox
            MinWidth="85"
            VerticalAlignment="Center"
            ItemsSource="{Binding LimitOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
            SelectedValue="{Binding DataCountPerPage, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <hc:ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding}" />
                        <TextBlock Text="&#x20;" />
                        <TextBlock Text="条/页" />
                    </StackPanel>
                </DataTemplate>
            </hc:ComboBox.ItemTemplate>
        </hc:ComboBox>
    </hc:UniformSpacingPanel>
</UserControl>