<UserControl
    x:Class="Admin.Desktop.UserControls.LogControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="uc"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ListBox
        x:Name="lst_log"
        Margin="1"
        HorizontalAlignment="Stretch"
        ItemsSource="{Binding ElementName=uc, Path=ItemsSource}"
        PreviewKeyDown="ListBox_PreviewKeyDown"
        Style="{StaticResource ListBox.Small}"
        VirtualizingPanel.IsVirtualizing="True">
        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="FontWeight" Value="Bold" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Border>
                    <TextBlock
                        Name="Msg"
                        Style="{Binding TextBlockStyle}"
                        Text="{Binding LogMessages}"
                        TextWrapping="Wrap" />
                </Border>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                        <Setter TargetName="Msg" Property="Foreground" Value="White" />
                        <Setter TargetName="Msg" Property="Background" Value="{Binding BackgroundBrush}" />
                        <Setter TargetName="Msg" Property="Padding" Value="2" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>