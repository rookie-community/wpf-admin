<Window
    x:Class="Admin.Desktop.View.Identity.OrganizationUnits.OrganizationUnitAddView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Identity.OrganizationUnits"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Identity.OrganizationUnits"
    Title="添加根机构"
    Width="350"
    Height="180"
    d:DataContext="{d:DesignInstance Type=viewmodel:OrganizationUnitAddVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <hc:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <hc:UniformSpacingPanel
                    Grid.Row="0"
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">
                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="机构名称"
                        hc:InfoElement.TitlePlacement="Top"
                        MaxLength="128"
                        Text="{Binding DisplayName}" />
                </hc:UniformSpacingPanel>
            </hc:ScrollViewer>

            <hc:UniformSpacingPanel
                Grid.Row="1"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SaveCommand}"
                    Content="{x:Static hc:Lang.Confirm}"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                    Command="{Binding CancelCommand}"
                    Content="{x:Static hc:Lang.Cancel}"
                    Style="{StaticResource ButtonDefault}" />
            </hc:UniformSpacingPanel>
        </Grid>
    </hc:DialogContainer>
</Window>
