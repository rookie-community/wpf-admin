<UserControl
    x:Class="Admin.Desktop.View.Identity.OrganizationUnits.OrganizationUnitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Identity.OrganizationUnits"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Admin.Desktop.UserControls"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Identity.OrganizationUnits"
    d:DataContext="{d:DesignInstance Type=viewmodel:OrganizationUnitVM}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" MinWidth="200" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="6*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <ToolBar HorizontalAlignment="Right" DockPanel.Dock="Top">
                    <Button
                        hc:IconElement.Geometry="{StaticResource AddGeometry}"
                        Command="{Binding AddRootCommand}"
                        Content="添加根机构" />
                </ToolBar>
                <TreeView ItemsSource="{Binding OrganizationUnits}" SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="5,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding DisplayName}" />
                                <hc:UniformSpacingPanel Margin="5,0" Spacing="3">
                                    <Button
                                        hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                        Command="{Binding DataContext.AddChildCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ButtonPrimary.Small}"
                                        ToolTip="添加子机构" />
                                    <Button
                                        hc:IconElement.Geometry="{StaticResource DropperGeometry}"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ButtonWarning.Small}"
                                        ToolTip="编辑" />
                                    <Button
                                        hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ButtonDanger.Small}"
                                        ToolTip="删除" />
                                </hc:UniformSpacingPanel>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <GridSplitter
                Grid.Column="1"
                Margin="1,0"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource DefaultBrush}" />

            <TabControl Grid.Column="2">
                <TabItem Header="成员">
                    <DockPanel>
                        <ToolBar HorizontalAlignment="Right" DockPanel.Dock="Top">
                            <Button
                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                Command="{Binding AddMemberCommand}"
                                Content="添加成员" />
                        </ToolBar>
                        <uc:PaginationPlus
                            Margin="1"
                            DataCountPerPage="{Binding UserDataCountPerPage}"
                            DockPanel.Dock="Bottom"
                            PageUpdatedCommand="{Binding UserPageChangedCommand}"
                            TotalCount="{Binding UserTotalCount}"
                            PageIndex="{Binding UserPageIndex}" />
                        <DataGrid
                            hc:DataGridAttach.ShowRowNumber="True"
                            AutoGenerateColumns="False"
                            HeadersVisibility="All"
                            ItemsSource="{Binding Users}"
                            RowHeaderWidth="60"
                            Style="{StaticResource DataGrid.Small}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding UserName}" Header="用户名" />
                                <DataGridTextColumn Binding="{Binding Email}" Header="邮件地址" />
                                <DataGridTemplateColumn Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:UniformSpacingPanel Spacing="5">
                                                <Button
                                                    hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                    Command="{Binding DataContext.DeleteMemberCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    Style="{StaticResource ButtonDanger.Small}" />
                                            </hc:UniformSpacingPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="角色">
                    <DockPanel>
                        <ToolBar HorizontalAlignment="Right" DockPanel.Dock="Top">
                            <Button
                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                Command="{Binding AddRoleCommand}"
                                Content="添加角色" />
                        </ToolBar>
                        <uc:PaginationPlus
                            Margin="1"
                            DataCountPerPage="{Binding RoleDataCountPerPage}"
                            DockPanel.Dock="Bottom"
                            PageUpdatedCommand="{Binding RolePageChangedCommand}"
                            TotalCount="{Binding RoleTotalCount}"
                            PageIndex="{Binding RolePageIndex}" />
                        <DataGrid
                            hc:DataGridAttach.ShowRowNumber="True"
                            AutoGenerateColumns="False"
                            HeadersVisibility="All"
                            ItemsSource="{Binding Roles}"
                            RowHeaderWidth="60"
                            Style="{StaticResource DataGrid.Small}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Header="角色名称" />
                                <DataGridTemplateColumn Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:UniformSpacingPanel Spacing="5">
                                                <Button
                                                    hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                    Command="{Binding DataContext.DeleteRoleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    Style="{StaticResource ButtonDanger.Small}" />
                                            </hc:UniformSpacingPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </hc:DialogContainer>
</UserControl>
