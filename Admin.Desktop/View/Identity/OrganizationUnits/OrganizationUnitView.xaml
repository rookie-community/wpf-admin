<UserControl
    x:Class="Admin.Desktop.View.Identity.OrganizationUnits.OrganizationUnitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Identity.OrganizationUnits"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Admin.Desktop.UserControls"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Identity.OrganizationUnits"
    d:DataContext="{d:DesignInstance Type=viewmodel:OrganizationUnitVM}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" MinWidth="200" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="6*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <ToolBar HorizontalAlignment="Right" DockPanel.Dock="Top">
                    <Button hc:IconElement.Geometry="{StaticResource AddGeometry}" Content="添加根机构" />
                </ToolBar>
                <TreeView />
            </DockPanel>

            <GridSplitter
                Grid.Column="1"
                Margin="1,0"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource DefaultBrush}" />

            <TabControl Grid.Column="2">
                <TabItem Header="成员">
                    <DockPanel>
                        <ToolBar HorizontalAlignment="Right" DockPanel.Dock="Top">
                            <Button hc:IconElement.Geometry="{StaticResource AddGeometry}" Content="添加成员" />
                        </ToolBar>
                        <uc:PaginationPlus
                            Margin="1"
                            DockPanel.Dock="Bottom"
                            PageChangedCommand="{Binding UserPageChangedCommand}"
                            PageSize="{Binding UserPageSize}"
                            TotalCount="{Binding UserTotalCount}"
                            PageIndex="{Binding UserPageIndex}" />
                        <DataGrid
                            hc:DataGridAttach.ShowRowNumber="True"
                            AutoGenerateColumns="False"
                            HeadersVisibility="All"
                            ItemsSource="{Binding AuditLogs}"
                            RowHeaderWidth="60"
                            Style="{StaticResource DataGrid.Small}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding UserName}" Header="用户名" />
                                <DataGridTextColumn Header="邮件地址" />
                                <DataGridTemplateColumn Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:UniformSpacingPanel Spacing="5">
                                                <Button
                                                    hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    Style="{StaticResource ButtonDanger.Small}"
                                                    Visibility="{Binding Path=DataContext.BtnPerms[Delete], RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                                            </hc:UniformSpacingPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="角色">
                    <DockPanel>
                        <ToolBar HorizontalAlignment="Right" DockPanel.Dock="Top">
                            <Button hc:IconElement.Geometry="{StaticResource AddGeometry}" Content="添加角色" />
                        </ToolBar>
                        <uc:PaginationPlus
                            Margin="1"
                            DockPanel.Dock="Bottom"
                            PageChangedCommand="{Binding RolePageChangedCommand}"
                            PageSize="{Binding RolePageSize}"
                            TotalCount="{Binding RoleTotalCount}"
                            PageIndex="{Binding RolePageIndex}" />
                        <DataGrid
                            hc:DataGridAttach.ShowRowNumber="True"
                            AutoGenerateColumns="False"
                            HeadersVisibility="All"
                            RowHeaderWidth="60"
                            Style="{StaticResource DataGrid.Small}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding UserName}" Header="角色名称" />
                                <DataGridTemplateColumn Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:UniformSpacingPanel Spacing="5">
                                                <Button
                                                    hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    Style="{StaticResource ButtonDanger.Small}"
                                                    Visibility="{Binding Path=DataContext.BtnPerms[Delete], RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                                            </hc:UniformSpacingPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </hc:DialogContainer>
</UserControl>
