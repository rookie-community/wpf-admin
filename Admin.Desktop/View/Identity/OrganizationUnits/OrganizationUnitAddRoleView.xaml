<Window
    x:Class="Admin.Desktop.View.Identity.OrganizationUnits.OrganizationUnitAddRoleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Identity.OrganizationUnits"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Admin.Desktop.UserControls"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Identity.OrganizationUnits"
    Title="添加角色"
    Width="600"
    Height="500"
    d:DataContext="{d:DesignInstance Type=viewmodel:OrganizationUnitAddRoleVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <!--  搜索条件  -->
            <hc:SearchBar
                Margin="10"
                hc:InfoElement.ShowClearButton="True"
                Command="{Binding SearchCommand}"
                CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}" />

            <!--  角色列表  -->
            <DataGrid
                Name="DG"
                Grid.Row="1"
                Margin="10,0"
                hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                AutoGenerateColumns="False"
                HeadersVisibility="All"
                IsReadOnly="True"
                ItemsSource="{Binding AvailableRoles}"
                RowHeaderWidth="60"
                Style="{StaticResource DataGrid.Small}">
                <DataGrid.RowHeaderTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
                    </DataTemplate>
                </DataGrid.RowHeaderTemplate>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                        Header="角色名称" />
                    <DataGridCheckBoxColumn
                        Width="80"
                        Binding="{Binding IsDefault}"
                        Header="默认" />
                    <DataGridCheckBoxColumn
                        Width="80"
                        Binding="{Binding IsPublic}"
                        Header="公开" />
                </DataGrid.Columns>
            </DataGrid>

            <!--  分页  -->
            <uc:PaginationPlus
                Grid.Row="2"
                Margin="10,1"
                DataCountPerPage="{Binding DataCountPerPage}"
                PageUpdatedCommand="{Binding PageChangedCommand}"
                TotalCount="{Binding TotalCount}"
                PageIndex="{Binding PageIndex}" />

            <!--  按钮区域  -->
            <hc:UniformSpacingPanel
                Grid.Row="3"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding ElementName=DG, Path=SelectedItems}"
                    Content="{x:Static hc:Lang.Confirm}"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                    Command="{Binding CancelCommand}"
                    Content="{x:Static hc:Lang.Cancel}"
                    Style="{StaticResource ButtonDefault}" />
            </hc:UniformSpacingPanel>
        </Grid>
    </hc:DialogContainer>
</Window>
