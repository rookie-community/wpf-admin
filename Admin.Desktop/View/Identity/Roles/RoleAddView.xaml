<Window
    x:Class="Admin.Desktop.View.Identity.Roles.RoleAddView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Identity.Roles"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.View.Identity.Roles"
    Title="新增角色"
    Width="300"
    Height="220"
    d:DataContext="{d:DesignInstance Type=viewmodel:RoleAddVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <hc:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <hc:UniformSpacingPanel
                    Grid.Row="0"
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">
                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="角色名称"
                        hc:InfoElement.TitlePlacement="Top"
                        MaxLength="20"
                        Text="{Binding Name}" />
                    <CheckBox Content="默认" IsChecked="{Binding IsDefault}" />
                    <CheckBox Content="公开" IsChecked="{Binding IsPublic}" />
                </hc:UniformSpacingPanel>
            </hc:ScrollViewer>

            <hc:UniformSpacingPanel
                Grid.Row="1"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SaveCommand}"
                    Content="保存"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource ButtonDefault}" />
            </hc:UniformSpacingPanel>
        </Grid>
    </hc:DialogContainer>
</Window>
