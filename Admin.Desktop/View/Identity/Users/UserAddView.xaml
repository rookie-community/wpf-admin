<Window
    x:Class="Admin.Desktop.View.Identity.Users.UserAddView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Identity.Users"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Identity.Users"
    Title="新增用户"
    Width="500"
    Height="520"
    d:DataContext="{d:DesignInstance Type=viewmodel:UserAddVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" TabStripPlacement="Top">
                <TabItem Header="用户信息">
                    <hc:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <hc:UniformSpacingPanel
                            Margin="10"
                            Orientation="Vertical"
                            Spacing="10">

                            <hc:TextBox
                                hc:InfoElement.Necessary="True"
                                hc:InfoElement.Title="用户名"
                                hc:InfoElement.TitlePlacement="Top"
                                MaxLength="20"
                                Text="{Binding UserName}" />
                            <hc:TextBox
                                hc:InfoElement.Title="名称"
                                hc:InfoElement.TitlePlacement="Top"
                                MaxLength="20"
                                Text="{Binding Name}" />
                            <hc:TextBox
                                hc:InfoElement.Title="姓氏"
                                hc:InfoElement.TitlePlacement="Top"
                                MaxLength="20"
                                Text="{Binding Surname}" />
                            <hc:PasswordBox
                                hc:InfoElement.Placeholder="请输入密码"
                                hc:InfoElement.ShowClearButton="True"
                                hc:InfoElement.Title="密码"
                                hc:InfoElement.TitlePlacement="Top"
                                IsSafeEnabled="False"
                                MaxLength="16"
                                ShowEyeButton="True"
                                UnsafePassword="{Binding CurrentPassword}" />
                            <hc:TextBox
                                hc:InfoElement.Necessary="True"
                                hc:InfoElement.Title="电子邮件"
                                hc:InfoElement.TitlePlacement="Top"
                                MaxLength="30"
                                Text="{Binding Email}" />
                            <hc:TextBox
                                hc:InfoElement.Title="电话号码"
                                hc:InfoElement.TitlePlacement="Top"
                                MaxLength="20"
                                Text="{Binding PhoneNumber}" />
                            <CheckBox Content="启用" IsChecked="{Binding IsActive}" />
                            <CheckBox IsChecked="{Binding LockoutEnabled}">
                                <CheckBox.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="账户锁定" />
                                        <TextBlock FontFamily="{StaticResource FA_Solid}" Text="&#xf05a;" />
                                    </StackPanel>
                                </CheckBox.Content>
                                <CheckBox.ToolTip>
                                    <TextBlock Text="登录尝试失败后锁定账户" />
                                </CheckBox.ToolTip>
                            </CheckBox>
                        </hc:UniformSpacingPanel>
                    </hc:ScrollViewer>
                </TabItem>
                <TabItem Header="角色">
                    <hc:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Roles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <hc:UniformSpacingPanel
                                        Margin="10"
                                        Orientation="Vertical"
                                        Spacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsDefault, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </hc:ScrollViewer>
                </TabItem>
            </TabControl>

            <hc:UniformSpacingPanel
                Grid.Row="1"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SaveCommand}"
                    Content="{x:Static hc:Lang.Confirm}"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                    Command="{Binding CancelCommand}"
                    Content="{x:Static hc:Lang.Cancel}"
                    Style="{StaticResource ButtonDefault}" />
            </hc:UniformSpacingPanel>
        </Grid>
    </hc:DialogContainer>
</Window>
