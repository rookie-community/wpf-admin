<hc:Window
    x:Class="Admin.Desktop.View.Accounts.Login"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ex="clr-namespace:Admin.Desktop.Tools.Extension"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:langs="clr-namespace:Admin.Desktop.Resources.Langs"
    xmlns:local="clr-namespace:Admin.Desktop.View.Accounts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.View.Accounts"
    Title="登录"
    Width="650"
    Height="450"
    d:DataContext="{d:DesignInstance Type=viewmodel:LoginVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    Icon="pack://application:,,,/Resources/Images/Icons/Logo.png"
    ResizeMode="CanMinimize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Image
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                HorizontalAlignment="Center"
                Source="/Resources/Images/login.png"
                Stretch="Uniform" />
            <hc:SimpleStackPanel
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <hc:UniformSpacingPanel Spacing="3">
                    <TextBlock
                        Margin="5"
                        HorizontalAlignment="Center"
                        FontSize="32"
                        FontWeight="Bold"
                        Style="{StaticResource TextBlockDefault}"
                        Text="Admin Sample" />
                </hc:UniformSpacingPanel>
                <hc:Shield
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Status="{Binding Version}"
                    Subject="{ex:Lang Key={x:Static langs:LangKeys.Version}}"
                    Color="#1182c3" />
                <hc:TextBox
                    hc:InfoElement.Placeholder="请输入租户"
                    hc:InfoElement.ShowClearButton="True"
                    hc:InfoElement.Title="{ex:Lang Key={x:Static langs:LangKeys.Tenant}}"
                    hc:InfoElement.TitlePlacement="Left"
                    Text="{Binding Tenant}" />
                <hc:Divider Margin="0,10" />
                <hc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                    <hc:TextBox
                        hc:InfoElement.Placeholder="请输入账号"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="{ex:Lang Key={x:Static langs:LangKeys.Account}}"
                        hc:InfoElement.TitlePlacement="Left"
                        Text="{Binding UserName}" />
                    <hc:PasswordBox
                        hc:InfoElement.Placeholder="请输入密码"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="{ex:Lang Key={x:Static langs:LangKeys.Password}}"
                        hc:InfoElement.TitlePlacement="Left"
                        IsSafeEnabled="False"
                        ShowEyeButton="True"
                        UnsafePassword="{Binding Password}">
                        <hc:PasswordBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SubmitCommand}" />
                        </hc:PasswordBox.InputBindings>
                    </hc:PasswordBox>
                    <hc:ComboBox
                        hc:InfoElement.Title="{ex:Lang Key={x:Static langs:LangKeys.Language}}"
                        hc:InfoElement.TitlePlacement="Left"
                        DisplayMemberPath="Key"
                        ItemsSource="{Binding LangItems}"
                        SelectedValue="{Binding CurrentLang}"
                        SelectedValuePath="Value" />

                    <ToggleButton
                        Command="{Binding SubmitCommand}"
                        Content="{ex:Lang Key={x:Static langs:LangKeys.Login}}"
                        IsChecked="{Binding IsUploading, Mode=TwoWay}"
                        Style="{StaticResource ToggleButtonLoadingPrimary}" />
                    <Button
                        Command="{Binding CancelCommand}"
                        Content="取消"
                        Style="{StaticResource ButtonDefault}"
                        Visibility="Collapsed" />
                </hc:UniformSpacingPanel>
            </hc:SimpleStackPanel>
            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                FontSize="12"
                Style="{StaticResource TextBlockDefaultSecLight}"
                Text="Copyright © 2026 Admin Sample" />
        </Grid>
    </hc:DialogContainer>
</hc:Window>
