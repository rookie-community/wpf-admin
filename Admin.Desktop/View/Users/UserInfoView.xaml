<UserControl
    x:Class="Admin.Desktop.View.Users.UserInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Users"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Users"
    d:DataContext="{d:DesignInstance Type=viewmodel:UserInfoVM}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <hc:UniformSpacingPanel
            Margin="10"
            Orientation="Vertical"
            Spacing="10">
            <hc:TextBox
                hc:InfoElement.Title="租户"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.TitleWidth="80"
                IsReadOnly="True"
                Text="{Binding TenantName}" />
            <hc:TextBox
                hc:InfoElement.Title="账号"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.TitleWidth="80"
                IsReadOnly="True"
                Text="{Binding Account}" />
            <hc:TextBox
                hc:InfoElement.Title="用户名"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.TitleWidth="80"
                MaxLength="20"
                Text="{Binding UserName}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Width="80" Text="是否激活" />
                <CheckBox IsChecked="{Binding IsActive}" IsEnabled="False" />
            </StackPanel>

            <hc:TextBox
                hc:InfoElement.Title="电话"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.TitleWidth="80"
                MaxLength="20"
                Text="{Binding PhoneNumber}" />
            <hc:TextBox
                hc:InfoElement.Title="邮箱"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.TitleWidth="80"
                MaxLength="30"
                Text="{Binding Email}" />
            <hc:UniformSpacingPanel Margin="80,0,0,0" Spacing="10">
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SubmitCommand}"
                    Content="确认修改"
                    Style="{DynamicResource ButtonPrimary}" />
                <Button
                    hc:IconElement.Geometry="{StaticResource RotateLeftGeometry}"
                    Command="{Binding ResetCommand}"
                    Content="重置" />
            </hc:UniformSpacingPanel>
        </hc:UniformSpacingPanel>
    </hc:DialogContainer>
</UserControl>
