<Window
    x:Class="Admin.Desktop.View.Tenants.TenantAddView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Tenants"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Tenants"
    Title="新增租户"
    Width="400"
    Height="280"
    d:DataContext="{d:DesignInstance Type=viewmodel:TenantAddVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <hc:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <hc:UniformSpacingPanel
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">

                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="用户名"
                        hc:InfoElement.TitlePlacement="Top"
                        MaxLength="20"
                        Text="{Binding Name}" />

                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="电子邮件"
                        hc:InfoElement.TitlePlacement="Top"
                        MaxLength="30"
                        Text="{Binding Email}" />
                    <hc:PasswordBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Placeholder="请输入密码"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="密码"
                        hc:InfoElement.TitlePlacement="Top"
                        IsSafeEnabled="False"
                        MaxLength="16"
                        ShowEyeButton="True"
                        UnsafePassword="{Binding Password}" />
                </hc:UniformSpacingPanel>
            </hc:ScrollViewer>

            <hc:UniformSpacingPanel
                Grid.Row="1"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SaveCommand}"
                    Content="保存"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource ButtonDefault}" />
            </hc:UniformSpacingPanel>
        </Grid>
    </hc:DialogContainer>
</Window>
