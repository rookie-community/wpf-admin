<UserControl
    x:Class="Admin.Desktop.View.SettingManagement.EmailSettings.EmailSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.SettingManagement.EmailSettings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.SettingManagement.EmailSettings"
    d:DataContext="{d:DesignInstance Type=viewmodel:EmailSettingVM}"
    d:DesignHeight="400"
    d:DesignWidth="600"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <hc:UniformSpacingPanel
            Margin="10"
            Orientation="Vertical"
            Spacing="10">
            <hc:TextBox
                hc:InfoElement.Necessary="True"
                hc:InfoElement.Title="默认显示名称"
                hc:InfoElement.TitlePlacement="Top"
                IsReadOnly="True"
                Text="{Binding EmailSettings.DefaultFromDisplayName}" />
            <hc:TextBox
                hc:InfoElement.Necessary="True"
                hc:InfoElement.Title="默认发件人"
                hc:InfoElement.TitlePlacement="Top"
                IsReadOnly="True"
                Text="{Binding EmailSettings.DefaultFromAddress}" />
            <hc:TextBox
                hc:InfoElement.Title="主机"
                hc:InfoElement.TitlePlacement="Top"
                MaxLength="20"
                Text="{Binding EmailSettings.SmtpHost}" />
            <hc:NumericUpDown
                hc:InfoElement.Title="端口"
                hc:InfoElement.TitlePlacement="Top"
                Maximum="65535"
                Minimum="1"
                Value="{Binding EmailSettings.SmtpPort}" />
            <CheckBox Content="启用ssl" IsChecked="{Binding EmailSettings.SmtpEnableSsl}" />
            <CheckBox Content="使用默认凭据" IsChecked="{Binding EmailSettings.SmtpUseDefaultCredentials}" />
            <hc:TextBox
                hc:InfoElement.Title="域"
                hc:InfoElement.TitlePlacement="Top"
                Text="{Binding EmailSettings.SmtpDomain}"
                Visibility="{Binding EmailSettings.SmtpUseDefaultCredentials, Converter={StaticResource InvertBoolToVisConverter}}" />
            <hc:TextBox
                hc:InfoElement.Title="用户名"
                hc:InfoElement.TitlePlacement="Top"
                Text="{Binding EmailSettings.SmtpUserName}"
                Visibility="{Binding EmailSettings.SmtpUseDefaultCredentials, Converter={StaticResource InvertBoolToVisConverter}}" />
            <hc:PasswordBox
                hc:InfoElement.Placeholder="请输入一个值以更新密码"
                hc:InfoElement.ShowClearButton="True"
                hc:InfoElement.Title="密码"
                hc:InfoElement.TitlePlacement="Top"
                IsSafeEnabled="False"
                MaxLength="16"
                ShowEyeButton="True"
                UnsafePassword="{Binding EmailSettings.SmtpPassword}"
                Visibility="{Binding EmailSettings.SmtpUseDefaultCredentials, Converter={StaticResource InvertBoolToVisConverter}}" />
            <hc:Divider Margin="5,0" />
            <hc:UniformSpacingPanel Spacing="10">
                <Button Command="{Binding SendTestEmailCommand}" Style="{StaticResource ButtonDashedPrimary}">
                    <hc:UniformSpacingPanel Spacing="4">
                        <TextBlock
                            Padding="2"
                            FontFamily="{StaticResource FA_Regular}"
                            Text="&#xf1d8;" />
                        <TextBlock Text="发送测试邮件" />
                    </hc:UniformSpacingPanel>
                </Button>
                <Button
                    hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                    Command="{Binding SubmitCommand}"
                    Content="保存"
                    Style="{DynamicResource ButtonPrimary}" />
            </hc:UniformSpacingPanel>
        </hc:UniformSpacingPanel>
    </hc:DialogContainer>
</UserControl>
