<Window
    x:Class="Admin.Desktop.View.SettingManagement.EmailSettings.SendTestEmailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.SettingManagement.EmailSettings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.SettingManagement.EmailSettings"
    Title="发送测试邮件"
    Width="600"
    Height="340"
    d:DataContext="{d:DesignInstance Type=viewmodel:SendTestEmailVM}"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <hc:DialogContainer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>
            <hc:ScrollViewer>
                <hc:UniformSpacingPanel
                    Grid.Row="0"
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">

                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="发件人邮箱地址"
                        hc:InfoElement.TitlePlacement="Top"
                        IsReadOnly="True"
                        Text="{Binding EmailInput.SenderEmailAddress}" />
                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="收件人邮箱地址"
                        hc:InfoElement.TitlePlacement="Top"
                        IsReadOnly="True"
                        Text="{Binding EmailInput.TargetEmailAddress}" />
                    <hc:TextBox
                        hc:InfoElement.Necessary="True"
                        hc:InfoElement.Title="主题"
                        hc:InfoElement.TitlePlacement="Top"
                        MaxLength="20"
                        Text="{Binding EmailInput.Subject}" />
                    <hc:TextBox
                        hc:InfoElement.Title="正文"
                        hc:InfoElement.TitlePlacement="Top"
                        MaxLength="20"
                        Text="{Binding EmailInput.Body}" />
                </hc:UniformSpacingPanel>
            </hc:ScrollViewer>

            <hc:UniformSpacingPanel
                Grid.Row="1"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button Command="{Binding SubmitCommand}" Style="{DynamicResource ButtonPrimary}">
                    <hc:UniformSpacingPanel Spacing="4">
                        <TextBlock
                            Padding="2"
                            FontFamily="{StaticResource FA_Regular}"
                            Text="&#xf1d8;" />
                        <TextBlock Text="发送" />
                    </hc:UniformSpacingPanel>
                </Button>
                <Button
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                    Command="{Binding CancelCommand}"
                    Content="取消" />
            </hc:UniformSpacingPanel>
        </Grid>
    </hc:DialogContainer>
</Window>
