<UserControl
    x:Class="Admin.Desktop.View.Reports.ReportDesign"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Design="clr-namespace:FastReport.Design;assembly=FastReport.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Reports"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.Reports"
    d:DataContext="{d:DesignInstance Type=viewmodel:ReportDesignVM}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <Design:WpfDesignerControl x:Name="designerControl" />
</UserControl>
