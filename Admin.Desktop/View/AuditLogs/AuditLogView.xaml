<UserControl
    x:Class="Admin.Desktop.View.AuditLogs.AuditLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Admin.Desktop.View.Users"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Admin.Desktop.UserControls"
    xmlns:viewmodel="clr-namespace:Admin.Desktop.ViewModel.AuditLogs"
    d:DataContext="{d:DesignInstance Type=viewmodel:AuditLogVM}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    hc:Dialog.Token="{Binding DialogContainerToken}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Expander
            Grid.Row="0"
            Header="搜索条件"
            IsExpanded="True">
            <Border
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,4,4">
                <hc:UniformSpacingPanel
                    Margin="5"
                    VerticalAlignment="Center"
                    ChildWrapping="Wrap"
                    Spacing="5">
                    <hc:TextBox
                        Width="180"
                        hc:InfoElement.Placeholder="请输入"
                        hc:InfoElement.ShowClearButton="True"
                        hc:InfoElement.Title="状态码"
                        hc:InfoElement.TitlePlacement="Left"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    <hc:DatePicker
                        Width="180"
                        hc:InfoElement.Title="开始日期"
                        hc:InfoElement.TitlePlacement="Left"
                        SelectedDate="{Binding StartTime}" />
                    <hc:DatePicker
                        Width="180"
                        hc:InfoElement.Title="结束日期"
                        hc:InfoElement.TitlePlacement="Left"
                        SelectedDate="{Binding EndTime}" />
                    <Button
                        hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                        Command="{Binding SearchCommand}"
                        Content="搜索"
                        Style="{StaticResource ButtonPrimary}"
                        Visibility="{Binding Buttons[Serach]}" />
                    <Button
                        hc:IconElement.Geometry="{StaticResource RotateLeftGeometry}"
                        Command="{Binding ResetCommand}"
                        Content="重置" />
                </hc:UniformSpacingPanel>
            </Border>
        </Expander>
        <ToolBar
            Grid.Row="1"
            Margin="0,2"
            Padding="0,5"
            HorizontalAlignment="Right">
            <hc:UniformSpacingPanel Spacing="5">
                <Button
                    hc:IconElement.Geometry="{StaticResource DownloadGeometry}"
                    Command="{Binding ExportCommand}"
                    Content="导出"
                    Style="{StaticResource ButtonDefault}"
                    Visibility="{Binding BtnPerms[Export]}" />
            </hc:UniformSpacingPanel>
        </ToolBar>
        <hc:DialogContainer Grid.Row="2">
            <DockPanel>
                <uc:PaginationPlus
                    Margin="1"
                    DockPanel.Dock="Bottom"
                    PageChangedCommand="{Binding PageChangedCommand}"
                    PageSize="{Binding PageSize}"
                    TotalCount="{Binding TotalCount}"
                    PageIndex="{Binding PageIndex}" />
                <DataGrid
                    Name="DG"
                    hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                    AutoGenerateColumns="False"
                    HeadersVisibility="All"
                    IsReadOnly="True"
                    ItemsSource="{Binding AuditLogs}"
                    RowHeaderWidth="60"
                    Style="{StaticResource DataGrid.Small}">
                    <DataGrid.RowHeaderTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
                        </DataTemplate>
                    </DataGrid.RowHeaderTemplate>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Binding="{Binding Id}"
                            Header="Id"
                            Visibility="Hidden" />
                        <DataGridTemplateColumn Header="状态码">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding HttpStatusCode}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HttpStatusCode}" Value="200">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HttpStatusCode}" Value="302">
                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="请求方式">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding HttpMethod}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HttpMethod}" Value="GET">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HttpMethod}" Value="POST">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HttpMethod}" Value="PUT">
                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HttpMethod}" Value="DELETE">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Binding="{Binding Url}" Header="接口" />
                        <DataGridTextColumn Binding="{Binding BrowserInfo}" Header="浏览器" />
                        <DataGridTextColumn Binding="{Binding UserName}" Header="用户" />
                        <DataGridTextColumn Binding="{Binding ClientIpAddress}" Header="IP地址" />
                        <DataGridTextColumn Binding="{Binding ExecutionTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}" Header="时间" />
                        <DataGridTextColumn Binding="{Binding ExecutionDuration, StringFormat={}{0} ms}" Header="耗时" />
                        <DataGridTextColumn Binding="{Binding ApplicationName}" Header="应用名称" />

                        <DataGridTemplateColumn Header="操作">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:UniformSpacingPanel Spacing="5">
                                        <Button
                                            hc:IconElement.Geometry="{StaticResource InfoGeometry}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="详情"
                                            Style="{StaticResource ButtonDefault.Small}"
                                            Visibility="{Binding Path=DataContext.BtnPerms[Edit], RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                                    </hc:UniformSpacingPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </hc:DialogContainer>
    </Grid>
</UserControl>

